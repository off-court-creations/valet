{
  // ─────────────────────────────────────────────────────────────
  // scripts/tsconfig.json | valet
  // Typecheck the previously-ungated Node tooling (TEST-CI S11 —
  // audit eslint.config.mjs:22 / §5 "~4,900 lines outside ESLint and
  // any typecheck"). Wired as `typecheck:scripts` in the typecheck chain.
  //
  // checkJs runs over the plain-JS build/release/MCP scripts + the CVA
  // CLI so broken imports, dead bindings, bad arities and obvious type
  // mistakes fail before publish. allowJs+checkJs, non-strict (these are
  // untyped JS); the React library keeps its own strict tsconfig, and the
  // MCP server (TypeScript) is typechecked via its own strict project
  // (npm run typecheck:mcp).
  //
  // Two files carry a documented `// @ts-nocheck` (flagged in the S11
  // report): scripts/mcp/extract-ts.mjs (drives the ts-morph node-union
  // API, which checkJs can't narrow without a real JSDoc refactor) —
  // behavior is covered by scripts/mcp/extractors.test.mjs and the
  // mcp:build gate.
  // ─────────────────────────────────────────────────────────────
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "../scripts/**/*.mjs",
    "../scripts/**/*.js",
    "../tsup.config.ts",
    "../vitest.config.ts",
    "../packages/create-valet-app/bin/**/*.js",
    "../packages/create-valet-app/scripts/**/*.mjs"
  ],
  "exclude": ["../node_modules", "../dist"]
}
