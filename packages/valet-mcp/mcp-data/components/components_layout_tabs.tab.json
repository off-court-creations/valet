{
  "name": "Tabs.Tab",
  "category": "layout",
  "slug": "components/layout/tabs.tab",
  "summary": "A clickable tab trigger inside `Tabs`, identified by `value`; pair each one with a matching `Tabs.Panel` of the same value — the parent `Tabs` owns the active selection and `tablist` ARIA.",
  "status": "experimental",
  "props": [
    {
      "name": "index",
      "type": "number",
      "required": false
    },
    {
      "name": "value",
      "type": "string | number",
      "required": false
    },
    {
      "name": "label",
      "type": "ReactNode",
      "required": false
    },
    {
      "name": "tooltip",
      "type": "ReactNode",
      "required": false
    },
    {
      "name": "preset",
      "type": "string | string[] | undefined",
      "required": false,
      "description": "One or many style-preset names registered via `definePreset()`"
    }
  ],
  "domPassthrough": {
    "element": "button",
    "omitted": []
  },
  "cssVars": [
    "--valet-focus-width",
    "--valet-focus-ring-color",
    "--valet-focus-offset",
    "--valet-underline-width",
    "--valet-space"
  ],
  "cssPresets": [],
  "events": [],
  "slots": [
    {
      "name": "label"
    },
    {
      "name": "tooltip"
    }
  ],
  "bestPractices": [],
  "examples": [],
  "docsUrl": "/tabs-demo",
  "sourceFiles": [
    "src/components/layout/Tabs.tsx"
  ],
  "version": "0.36.0",
  "schemaVersion": "1.7"
}